{
      "name": "Datos Abiertos",
      "version": "0.1.0",
      "private": true,
      "dependencies": {
            "@supabase/supabase-js": "^2",
            "ical.js": "^2.2.1",
            "lucide-react": "^0.487.0",
            "motion": "*",
            "pigeon-maps": "*",
            "react": "^18.3.1",
            "react-dom": "^18.3.1",
            "react-markdown": "^10.1.0",
            "react-router-dom": "^7.10.1",
            "rehype-raw": "^7.0.0",
            "remark-gfm": "^4.0.1"
      },
      "devDependencies": {
            "@testing-library/jest-dom": "^6.9.1",
            "@testing-library/react": "^16.3.1",
            "@testing-library/user-event": "^14.6.1",
            "@types/node": "^20.10.0",
            "@types/react": "^19.2.7",
            "@types/react-dom": "^19.2.3",
            "@typescript-eslint/eslint-plugin": "^8.50.0",
            "@typescript-eslint/parser": "^8.50.0",
            "@vitejs/plugin-react-swc": "^3.10.2",
            "axe-core": "^4.10.3",
            "eslint": "^8.57.1",
            "eslint-plugin-react-hooks": "^7.0.1",
            "eslint-plugin-react-refresh": "^0.4.26",
            "jsdom": "^27.3.0",
            "prettier": "^3.7.4",
            "rollup-plugin-visualizer": "^5.14.0",
            "vite": "^6.4.1",
            "vitest": "^4.0.16"
      },
      "scripts": {
            "dev": "vite",
            "prebuild": "node scripts/fetch-calendar-events.mjs && node scripts/copy-email-logo.mjs",
            "sync-email-logo": "node scripts/copy-email-logo.mjs",
            "build": "vite build",
            "build:analyze": "ANALYZE=1 vite build",
            "lint": "eslint . --ext ts,tsx",
            "perf:scan": "react-perf-analyzer ./src --fail-on high",
            "perf:changed": "react-perf-analyzer ./src --only-changed --fail-on high",
            "perf:baseline": "react-perf-analyzer ./src --format json --output .sast-baseline.json",
            "perf:ci": "react-perf-analyzer ./src --format sarif --output react-perf-results.sarif --fail-on high",
            "preview": "vite preview",
            "test": "vitest run",
            "test:a11y": "vitest run src/test/OrganizationProfileForm.a11y.test.tsx",
            "test:watch": "vitest",
            "format": "prettier --write ."
      }
}
